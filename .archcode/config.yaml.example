# ArchCode 配置示例
# 复制到 .archcode/config.yaml 并填入你的 API Key

providers:
  - name: default
    protocol: openai-compat   # openai-compat | openai | anthropic
    base_url: https://api.openai.com/v1
    model: gpt-4o-mini
    api_key: ${OPENAI_API_KEY}   # 或直接写 sk-xxx
    max_output_tokens: 4096
    # thinking: false            # anthropic 可开

# 可选：追加到系统提示词
# system_prompt: |
#   请用中文回答。
